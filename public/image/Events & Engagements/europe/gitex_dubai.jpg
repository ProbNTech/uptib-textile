    <script type="9d146ffddd4037bdfd94dbca-text/javascript">
        $(document).ready(function () {
            // Apply both lazy loading and async decoding to all images
            function applyLazyAndAsync(imgs) {
                $(imgs).each(function () {
                    this.setAttribute('loading', 'lazy');
                    this.setAttribute('decoding', 'async');
                });
            }

            // 1️⃣ Apply to all images currently in the DOM
            applyLazyAndAsync($('img'));

            // 2️⃣ Observe dynamically added images
            const observer = new MutationObserver(() => {
                applyLazyAndAsync($('img'));
            });
            observer.observe(document.body, { childList: true, subtree: true });

            $('img').each(function () {
                const img = this;

                // Skip if already has width/height attributes
                if (img.hasAttribute('width') && img.hasAttribute('height')) return;

                // Wait until the image is fully loaded to get rendered size
                if (img.complete) {
                    img.setAttribute('width', img.clientWidth);
                    img.setAttribute('height', img.clientHeight);
                } else {
                    img.onload = function () {
                        img.setAttribute('width', img.clientWidth);
                        img.setAttribute('height', img.clientHeight);
                    };
                }

                // Ensure lazy-loading and async decoding
                img.setAttribute('loading', 'lazy');
                img.setAttribute('decoding', 'async');
            });

        });
    </script>

    

    
    


